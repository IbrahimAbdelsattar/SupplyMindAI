# ==============================================================================
# SupplyMind AI — Environment Reference Template
# ==============================================================================

# ══════════════════════════════════════════════════════════════════════════════
# APPLICATION ENVIRONMENT
# ══════════════════════════════════════════════════════════════════════════════
ENVIRONMENT=development

# ══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://postgres.zjugkebpmiworbxcrjrm:[YOUR_SUPABASE_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require
POSTGRES_USER=supplymind
POSTGRES_PASSWORD=password
POSTGRES_DB=supplymind
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_CONNECT_TIMEOUT=10
DB_POOL_TIMEOUT=30
REDIS_URL=redis://redis:6379

# ══════════════════════════════════════════════════════════════════════════════
# SECURITY & CORS
# ══════════════════════════════════════════════════════════════════════════════
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# Clerk JWKS verification — required for backend JWT verification
# Backend uses this to extract the Clerk domain for JWKS key fetching
CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE
# Clerk secret key — used by backend for API calls (optional for JWT verification)
CLERK_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# ══════════════════════════════════════════════════════════════════════════════
# LLM / AI PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════
LLM_PROVIDER=nararouter
OPENAI_API_KEY=sk-nry-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://router.bynara.id/v1
LLM_MODEL=qwen/qwen3-coder:free

# Feature Flags
ENABLE_COPILOT=true
ENABLE_RAG=true
ENABLE_AI_INSIGHTS=true
ENABLE_FORECAST_INSIGHTS=true
RESTRICT_CHATBOT=true # If true, forces chatbot to only act as customer support, restricting business data/technical code access.

# ══════════════════════════════════════════════════════════════════════════════
# EMBEDDINGS & VECTORS
# ══════════════════════════════════════════════════════════════════════════════
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
KNOWLEDGE_MATCH_THRESHOLD=0.45
KNOWLEDGE_MATCH_COUNT=8
KNOWLEDGE_BATCH_EMBED_SIZE=32
KNOWLEDGE_INGESTION_ASYNC=true
RAG_WARM_UP_ON_STARTUP=false

# ══════════════════════════════════════════════════════════════════════════════
# LANGCHAIN / LANGSMITH OBSERVABILITY
# ══════════════════════════════════════════════════════════════════════════════
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=supplymind-dev
COPILOT_USE_LANGGRAPH=true

# ══════════════════════════════════════════════════════════════════════════════
# MODELING, MLOps & STORAGE
# ══════════════════════════════════════════════════════════════════════════════
MODEL_PATH=./Modeling/demand_model_pipeline.pkl
FORECAST_CSV_PATH=./Modeling/future_forecast.csv
DRIFT_THRESHOLD=0.05
STORAGE_PATH=./data/storage
LOG_LEVEL=DEBUG

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND
# ══════════════════════════════════════════════════════════════════════════════
VITE_API_URL=http://localhost:8081/api/v1
# Clerk publishable key for frontend (Vite inlines this at BUILD time)
# MUST match the domain used in CLERK_PUBLISHABLE_KEY above
# Dev: pk_test_xxx  |  Prod: pk_live_xxx
VITE_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE


# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT (docker-compose.prod.yml)
# ══════════════════════════════════════════════════════════════════════════════
# These are required when deploying with docker-compose.prod.yml.
# Set REDIS_PASSWORD to a strong random value.
REDIS_PASSWORD=change-me-to-a-strong-password

# Docker images (set to your registry path)
BACKEND_IMAGE=supplymind-backend:latest
FRONTEND_IMAGE=supplymind-frontend:latest
WORKER_IMAGE=supplymind-worker:latest

# LLM API key (no default in production — must be set)
OPENROUTER_API_KEY=sk-nry-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
