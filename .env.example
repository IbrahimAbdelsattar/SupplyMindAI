# ==============================================================================
# SupplyMind AI - Environment Configuration Example
# ==============================================================================

# ── APPLICATION ENVIRONMENT ──────────────────────────────────────────────────
NODE_ENV=production
ENVIRONMENT=production

# ── INFRASTRUCTURE ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://supplymind:password@postgres:5432/supplymind
POSTGRES_USER=supplymind
POSTGRES_PASSWORD=password
POSTGRES_DB=supplymind

REDIS_URL=redis://redis:6379

# ── FRONTEND SETTINGS ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CHAT_URL=http://localhost:8000/api/v1/chat

# ── SECURITY SECRETS ─────────────────────────────────────────────────────────
# WARNING: Change these in production!
JWT_SECRET=super-secret-key-change-in-production
SESSION_SECRET=super-secret-session-key-change-in-production

# ── LLM / AI SECRETS ─────────────────────────────────────────────────────────
# Obtain an OpenRouter key to power the AI Insights and RAG Chat features
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=deepseek/deepseek-v4-flash:free
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── MLOps CONFIGURATION ──────────────────────────────────────────────────────
# Artifact locations (if persistent volumes mapped outside containers)
MODEL_PATH=./Modeling/demand_model_pipeline.pkl
REPORT_STORAGE_PATH=./data/reports/
DRIFT_THRESHOLD=0.05
LOG_LEVEL=INFO
