# ==============================================================================
# SupplyMind AI - Environment Configuration Example
# ==============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── APPLICATION ENVIRONMENT ──────────────────────────────────────────────────
ENVIRONMENT=production

# ── INFRASTRUCTURE ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://supplymind:password@postgres:5432/supplymind
POSTGRES_USER=supplymind
POSTGRES_PASSWORD=password
POSTGRES_DB=supplymind
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── FRONTEND SETTINGS ────────────────────────────────────────────────────────
# In Docker, the nginx proxy forwards /api/ to the backend container
VITE_API_URL=/api/v1

# ── SECURITY SECRETS ─────────────────────────────────────────────────────────
# WARNING: Change these in production!
JWT_SECRET=change-me-to-a-random-64-char-string
AUTHORIZED_EMAILS=

# ── LLM / AI SECRETS ─────────────────────────────────────────────────────────
# Obtain an OpenRouter key at https://openrouter.ai/keys
RAG_API_KEY=replace-with-openrouter-rag-key
LLM_REASONING_API_KEY=replace-with-openrouter-reasoning-key
CHATBOT_API_KEY=replace-with-openrouter-chatbot-key
LLM_MODEL=moonshotai/kimi-k2.6:free
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Local knowledge vectors and agent memory are stored in DATABASE_URL.
STORAGE_PATH=./data/storage
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
KNOWLEDGE_MATCH_THRESHOLD=0.45
KNOWLEDGE_MATCH_COUNT=8
KNOWLEDGE_BATCH_EMBED_SIZE=32
KNOWLEDGE_INGESTION_ASYNC=true
EMBEDDING_DIMENSION=384
COPILOT_USE_LANGGRAPH=true

# ── LANGSMITH OBSERVABILITY (optional) ────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_your-key-here
LANGCHAIN_PROJECT=supplymind-ai

# ── MLOps CONFIGURATION ──────────────────────────────────────────────────────
MODEL_PATH=/app/Modeling/demand_model_pipeline.pkl
FORECAST_CSV_PATH=/app/Modeling/future_forecast.csv
REPORT_STORAGE_PATH=/app/data/reports/
DRIFT_THRESHOLD=0.05
LOG_LEVEL=INFO
