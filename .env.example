# ==============================================================================
# SupplyMind AI — Environment Reference Template
# ==============================================================================
# This file documents EVERY environment variable the application reads.
# Copy relevant sections to your .env file and fill in your values.
#
# Quick start:
#   cp .env.example .env   (then edit .env)

# ══════════════════════════════════════════════════════════════════════════════
# APPLICATION ENVIRONMENT
# ══════════════════════════════════════════════════════════════════════════════
# One of: development, staging, production
ENVIRONMENT=development

# ══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════════════════════════════════════
# Example (PostgreSQL local):
#   DATABASE_URL=postgresql://supplymind:password@localhost:5433/supplymind
# Example (SQLite dev):
#   DATABASE_URL=sqlite:///./supplymind.db
# Example (Docker Compose):
#   DATABASE_URL=postgresql://supplymind:password@postgres:5432/supplymind
DATABASE_URL=postgresql://supplymind:password@localhost:5433/supplymind

# PostgreSQL credentials (used by docker-compose / init scripts, not app code)
POSTGRES_USER=supplymind
POSTGRES_PASSWORD=password
POSTGRES_DB=supplymind

# Connection pool tuning (PostgreSQL only; ignored for SQLite)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis (for caching / sessions; currently used by docker-compose only)
REDIS_URL=redis://redis:6379

# ══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ══════════════════════════════════════════════════════════════════════════════
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string
# Session secret (for cookie-based sessions; generate the same way)
SESSION_SECRET=change-me-to-a-random-64-char-string

# Comma-separated list of emails allowed to register (empty = open registration)
AUTHORIZED_EMAILS=

# Comma-separated CORS origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3000,http://localhost:5173

# Comma-separated host/domain allow list for request validation
ALLOWED_HOSTS=localhost,127.0.0.1,testserver

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Default role assigned to new users (admin, manager, analyst, viewer)
DEFAULT_USER_ROLE=analyst

# ══════════════════════════════════════════════════════════════════════════════
# DEFAULT SEED USERS (development / staging only)
# ══════════════════════════════════════════════════════════════════════════════
# These are only used when ENVIRONMENT != production.
# If unset, defaults are: admin@supplymind.ai / Admin@123! / demo@supplymind.ai / demo
# ADMIN_EMAIL=admin@supplymind.ai
# ADMIN_PASSWORD=Admin@123!
# DEMO_EMAIL=demo@supplymind.ai
# DEMO_PASSWORD=demo

# ══════════════════════════════════════════════════════════════════════════════
# LLM / AI PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════
# The LLM client resolves keys in this priority order:
#   1. LLM_REASONING_API_KEY  2. RAG_API_KEY  3. CHATBOT_API_KEY  4. OPENROUTER_API_KEY
# You only need to set ONE key for most deployments (OpenRouter recommended).
# Obtain a key at https://openrouter.ai/keys
#
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LLM_REASONING_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RAG_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# CHATBOT_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Custom OpenAI-compatible base URL (leave empty for auto-detect based on key prefix)
LLM_BASE_URL=

# LLM model identifier (auto-selected based on key prefix if unset)
LLM_MODEL=moonshotai/kimi-k2.6:free

# Language model routing (overrides for specific agents; all default to glm5.1)
# LLM_REASONING_MODEL=openai/gpt-4o-mini
# COPILOT_MODEL=openai/gpt-4o-mini
# RAG_MODEL=openai/gpt-4o-mini
# FORECAST_MODEL=openai/gpt-4o-mini

# ══════════════════════════════════════════════════════════════════════════════
# EMBEDDINGS & VECTORS
# ══════════════════════════════════════════════════════════════════════════════
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Knowledge / RAG retrieval tuning
KNOWLEDGE_MATCH_THRESHOLD=0.45
KNOWLEDGE_MATCH_COUNT=8
KNOWLEDGE_BATCH_EMBED_SIZE=32
KNOWLEDGE_INGESTION_ASYNC=true
RAG_WARM_UP_ON_STARTUP=false

# ══════════════════════════════════════════════════════════════════════════════
# LANGSMITH OBSERVABILITY (optional)
# ══════════════════════════════════════════════════════════════════════════════
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=supplymind-ai

# ══════════════════════════════════════════════════════════════════════════════
# COPILOT / LANGGRAPH
# ══════════════════════════════════════════════════════════════════════════════
COPILOT_USE_LANGGRAPH=true

# ══════════════════════════════════════════════════════════════════════════════
# MODELING & MLOps
# ══════════════════════════════════════════════════════════════════════════════
MODEL_PATH=/app/Modeling/demand_model_pipeline.pkl
FORECAST_CSV_PATH=/app/Modeling/future_forecast.csv
DRIFT_THRESHOLD=0.05

# ══════════════════════════════════════════════════════════════════════════════
# STORAGE
# ══════════════════════════════════════════════════════════════════════════════
STORAGE_PATH=./data/storage

# ══════════════════════════════════════════════════════════════════════════════
# FRONTEND (consumed by the Vite / Next.js build step)
# ══════════════════════════════════════════════════════════════════════════════
VITE_API_URL=/api/v1

# ══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
