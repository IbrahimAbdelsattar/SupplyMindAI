# ==============================================================================
# SupplyMind AI - Environment Configuration Example
# ==============================================================================

# ── APPLICATION ENVIRONMENT ──────────────────────────────────────────────────
ENVIRONMENT=production

# ── INFRASTRUCTURE ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://supplymind:password@postgres:5432/supplymind
POSTGRES_USER=supplymind
POSTGRES_PASSWORD=password
POSTGRES_DB=supplymind

REDIS_URL=redis://redis:6379

# ── FRONTEND SETTINGS ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CHAT_URL=http://localhost:8000/api/v1/chat
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ── SECURITY SECRETS ─────────────────────────────────────────────────────────
# WARNING: Change these in production!
JWT_SECRET=super-secret-key-change-in-production
SESSION_SECRET=super-secret-session-key-change-in-production

# ── LLM / AI SECRETS ─────────────────────────────────────────────────────────
# Obtain an OpenRouter key to power the AI Insights and RAG Chat features
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=deepseek/deepseek-v4-flash:free
EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_WARM_UP_ON_STARTUP=false

# ── SUPABASE INTELLIGENCE LAYER (vectors, RAG, copilot — not operational DB) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
KNOWLEDGE_MATCH_THRESHOLD=0.45
KNOWLEDGE_MATCH_COUNT=8
KNOWLEDGE_BATCH_EMBED_SIZE=32
KNOWLEDGE_INGESTION_ASYNC=true
EMBEDDING_DIMENSION=384
COPILOT_USE_LANGGRAPH=true

# ── LANGSMITH OBSERVABILITY ──────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=supplymind-ai

# ── MLOps CONFIGURATION ──────────────────────────────────────────────────────
# Artifact locations (if persistent volumes mapped outside containers)
MODEL_PATH=./Modeling/demand_model_pipeline.pkl
REPORT_STORAGE_PATH=./data/reports/
DRIFT_THRESHOLD=0.05
LOG_LEVEL=INFO
