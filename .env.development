# ==============================================================================
# SupplyMind AI — Development Environment
# ==============================================================================

ENVIRONMENT=development

DATABASE_URL=postgresql://postgres:[YOUR_SUPABASE_PASSWORD]@db.zjugkebpmiworbxcrjrm.supabase.co:6543/postgres?sslmode=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

JWT_SECRET=dev-insecure-jwt-secret-change-in-production
SESSION_SECRET=dev-insecure-session-secret-change-in-production
AUTHORIZED_EMAILS=admin@supplymind.ai
ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
DEFAULT_USER_ROLE=analyst

OPENROUTER_API_KEY=
LLM_BASE_URL=
LLM_MODEL=moonshotai/kimi-k2.6:free

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
KNOWLEDGE_MATCH_THRESHOLD=0.45
KNOWLEDGE_MATCH_COUNT=8
KNOWLEDGE_BATCH_EMBED_SIZE=32
KNOWLEDGE_INGESTION_ASYNC=true
RAG_WARM_UP_ON_STARTUP=false

LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=supplymind-dev

COPILOT_USE_LANGGRAPH=true

MODEL_PATH=./Modeling/demand_model_pipeline.pkl
FORECAST_CSV_PATH=./Modeling/future_forecast.csv
DRIFT_THRESHOLD=0.05

STORAGE_PATH=./data/storage

VITE_API_URL=http://localhost:8081/api/v1

LOG_LEVEL=DEBUG
