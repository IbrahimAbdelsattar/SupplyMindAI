# ==============================================================================
# SupplyMind AI - Production Environment Configuration
# ==============================================================================
# IMPORTANT: This is a TEMPLATE. Update all values before deploying to production.
# Store this file securely and never commit sensitive values to version control.

# ── APPLICATION ENVIRONMENT ──────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── INFRASTRUCTURE ───────────────────────────────────────────────────────────
# Update these with your production database credentials
DATABASE_URL=postgresql://supplymind_prod:CHANGE_ME_STRONG_PASSWORD@postgres:5432/supplymind_prod
POSTGRES_USER=supplymind_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=supplymind_prod

# Redis connection for caching and sessions
REDIS_URL=redis://redis:6379

# ── FRONTEND SETTINGS ────────────────────────────────────────────────────────
# Update with your production domain
VITE_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
NEXT_PUBLIC_CHAT_URL=https://api.yourdomain.com/api/v1/chat

# CORS: Add your production domain(s) - comma-separated, no trailing slashes
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com

# ── SECURITY SECRETS ─────────────────────────────────────────────────────────
# WARNING: Generate strong random values for production!
# Generate JWT_SECRET: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE_WITH_OPENSSL
# Generate SESSION_SECRET: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE_WITH_OPENSSL

# Access token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Default role for new users (admin, manager, analyst, viewer)
DEFAULT_USER_ROLE=analyst

# ── LLM / AI CONFIGURATION ───────────────────────────────────────────────────
# OpenRouter API Key for LLM functionality
# Get from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-CHANGE_ME_YOUR_KEY

# LLM Model selection
LLM_MODEL=deepseek/deepseek-v4-flash:free

# Embedding model for RAG
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# RAG warmup (set to true to index knowledge at startup)
RAG_WARM_UP_ON_STARTUP=false

# ── SUPABASE INTELLIGENCE LAYER & STORAGE ──────────────────────────────────
# Supabase provides THREE critical services:
# 1. Authentication (user signup/signin) — handles all user auth
# 2. Vector Storage (RAG embeddings) — intelligence layer with pgvector
# 3. File Storage (documents, reports, data) — cloud file storage

# Create project at: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co

# Get from Supabase dashboard → Settings → API Keys
# ANON_KEY: Used by frontend for authentication
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME
# SERVICE_ROLE_KEY: Used by backend for admin operations (KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME

# ── AUTHENTICATION CONFIGURATION ────────────────────────────────────────────
# Email confirmation settings (configure in Supabase dashboard → Authentication)
# Options: implicit, explicit, none
SUPABASE_AUTH_EMAIL_CONFIRMATION=explicit

# Password requirements (configure in Supabase dashboard)
# Recommended: minimum 8 characters with complexity checks

# Session management (automatic via Supabase)
# Default: Access tokens expire in 1 hour, refresh tokens in 7 days

# ── STORAGE CONFIGURATION ──────────────────────────────────────────────────
# Storage buckets (created by migration in supabase/migrations/)
# - documents: PDFs, Word docs (20MB max, user-isolated)
# - data-imports: CSV, Excel files (50MB max, user-isolated)
# - reports: Generated reports (20MB max, user-isolated)
# - forecasts: Forecast exports (10MB max, user-isolated)
# - avatars: Profile pictures (5MB max, public)

# ── KNOWLEDGE/RAG SETTINGS ─────────────────────────────────────────────────
# Vector embeddings stored in Supabase with pgvector
KNOWLEDGE_MATCH_THRESHOLD=0.45
KNOWLEDGE_MATCH_COUNT=8
KNOWLEDGE_BATCH_EMBED_SIZE=32
KNOWLEDGE_INGESTION_ASYNC=true
COPILOT_USE_LANGGRAPH=true

# ── LANGSMITH OBSERVABILITY (Optional) ───────────────────────────────────────
# For LLM tracing and debugging - set LANGCHAIN_TRACING_V2=false to disable
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=CHANGE_ME_YOUR_LANGSMITH_KEY
LANGCHAIN_PROJECT=supplymind-production

# ── DOCKER SETTINGS ──────────────────────────────────────────────────────────
# For docker deployments
COMPOSE_PROJECT_NAME=supplymind-prod
