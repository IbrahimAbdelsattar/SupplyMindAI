# ==============================================================================
# SupplyMind AI — Staging Environment
# ==============================================================================

ENVIRONMENT=staging

DATABASE_URL=postgresql://supplymind_staging:CHANGE_ME_STRONG_PASSWORD@postgres:5432/supplymind_staging
POSTGRES_USER=supplymind_staging
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=supplymind_staging
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

REDIS_URL=redis://redis:6379

JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE_WITH_OPENSSL
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_VALUE_WITH_OPENSSL
AUTHORIZED_EMAILS=
ALLOWED_ORIGINS=https://staging.yourdomain.com,https://api-staging.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,staging.yourdomain.com
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30
DEFAULT_USER_ROLE=analyst

OPENROUTER_API_KEY=sk-or-CHANGE_ME_YOUR_KEY
LLM_MODEL=moonshotai/kimi-k2.6:free

EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
KNOWLEDGE_MATCH_THRESHOLD=0.45
KNOWLEDGE_MATCH_COUNT=8
KNOWLEDGE_BATCH_EMBED_SIZE=32
KNOWLEDGE_INGESTION_ASYNC=true
RAG_WARM_UP_ON_STARTUP=false

LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=CHANGE_ME_YOUR_LANGSMITH_KEY
LANGCHAIN_PROJECT=supplymind-staging

COPILOT_USE_LANGGRAPH=true

MODEL_PATH=/app/Modeling/demand_model_pipeline.pkl
FORECAST_CSV_PATH=/app/Modeling/future_forecast.csv
DRIFT_THRESHOLD=0.05

STORAGE_PATH=/app/data/storage

VITE_API_URL=https://api-staging.yourdomain.com/api/v1

LOG_LEVEL=INFO
